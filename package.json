{
  "name": "md-reader",
  "version": "1.0.0",
  "description": "轻量 Markdown 阅读器",
  "main": "electron/main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build:mac": "electron-builder --mac",
    "build:mac:zip": "electron-builder --mac zip",
    "build:mac:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.mdreader.app",
    "productName": "Markdown Reader",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "extendInfo": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Markdown File",
            "CFBundleTypeRole": "Viewer",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "net.daringfireball.markdown",
              "public.plain-text"
            ],
            "CFBundleTypeExtensions": [
              "md",
              "markdown",
              "mdown",
              "mkd",
              "txt"
            ]
          }
        ]
      }
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.1.0"
  }
}
